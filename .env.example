# Database connection URI. Neon Postgres requires sslmode=require.
# For local dev: postgresql+asyncpg://postgres:postgres@localhost:5433/tms_postgres
# For production: postgresql+asyncpg://<user>:<password>@<neon-host>/<db>?sslmode=require
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/tms_postgres

# Secret key for session signing and fallback encryption.
SECRET_KEY=generate-a-long-random-string-for-production

# Dedicated secret key for JWT token encoding/decoding.
# Must be set in production environments.
JWT_SECRET=generate-another-long-random-string-for-jwt

# Environment toggle (development / production)
ENVIRONMENT=development

# Server port to run on
PORT=8000

# Comma-separated list of allowed CORS origins
# E.g., http://localhost:5173,https://your-app.vercel.app
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Redis connection URL
REDIS_URL=redis://localhost:6379/0

# Logging level (development / production / warning / info / error)
LOG_LEVEL=development
